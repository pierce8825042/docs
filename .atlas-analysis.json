  "keyFeatures": [
    "Bulk SMS/MMS campaigns with scheduling, A/B testing, and link tracking",
    "Text-message polls with branching logic and shareable results",
    "Two-way inbox for managing replies and conversations",
    "Contact management with CSV/Excel import, tags, segments, and custom fields",
    "Visual workflow automation builder with triggers and actions",
    "Analytics dashboard with delivery rates, reply rates, and click attribution",
    "Multi-tenant organizations with role-based access control",
    "Credit-based billing with subscription plans",
    "TCPA-compliant quiet hours and opt-out management",
    "Real-time delivery status via Twilio integration"
  ],
  "publicApiSurface": [
    "POST /api/campaigns — create a campaign",
    "PATCH /api/campaigns/:id — update a campaign",
    "GET /api/campaigns — list campaigns",
    "POST /api/campaigns/:id/send — send a campaign",
    "POST /api/polls/:id/start — start a poll",
    "GET /api/contacts — list contacts",
    "POST /api/contacts — create a contact",
    "GET /api/contacts/:id — get contact detail",
    "POST /api/contacts/import — import contacts",
    "GET /api/analytics/dashboard — dashboard metrics",
    "GET /api/billing/status — billing and subscription status",
    "GET /api/credits/balance — credit balance",
    "POST /api/billing/create-order — create a billing order",
    "GET /api/phone-numbers — list phone numbers",
    "POST /api/messages — send a one-off message",
    "GET /api/conversations — list conversations",
    "POST /api/onboarding/join-org — join organization via onboarding"
  ]
